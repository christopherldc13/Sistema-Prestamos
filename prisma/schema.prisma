generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}



model User {
  id                 String     @id @default(auto()) @map("_id") @db.ObjectId
  name               String?
  email              String     @unique
  password           String
  role               String     @default("admin") // "superadmin" or "admin"
  isActive           Boolean    @default(true)
  phone              String?
  licenseExpiresAt   DateTime?
  subscriptionPlan   String     @default("basic")

  // Personalización del plan por usuario — si un campo es null, se hereda el valor
  // de la plantilla `subscriptionPlan` (ver resolveUserPlan en src/lib/plans.ts).
  maxClients            Int?
  maxActiveLoans        Int?
  maxPaymentHistory     Int?
  hasContractPDF        Boolean?
  hasStatementPDF       Boolean?
  hasFrenchAmortization Boolean?
  hasAmortizationTable  Boolean?
  hasAdvancedReports    Boolean?
  hasExport             Boolean?
  hasCustomBranding     Boolean?
  planPrice             Float?

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  clients   Client[]
  loans     Loan[]
  settings  Settings?
}

model Client {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId
  user        User?    @relation(fields: [userId], references: [id])
  fullName    String
  idNumber    String   @unique
  phone       String
  address     String
  email       String?
  loans       Loan[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Loan {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String?   @db.ObjectId
  user              User?     @relation(fields: [userId], references: [id])
  amount            Float
  interestRate      Float
  rateFrequency     String    @default("monthly") // "daily" | "weekly" | "biweekly" | "monthly" | "annual"
  status            String    @default("active")  // "active", "paid", "overdue"
  term              Int
  termUnit          String    // "days", "weeks", "months"
  interestType      String    // "simple", "compound"
  startDate         DateTime  @default(now())
  dueDate           DateTime?
  totalToPay        Float
  installmentAmount Float?
  remainingBalance  Float
  paymentSchedule   Json?
  clientId          String    @db.ObjectId
  client            Client    @relation(fields: [clientId], references: [id])
  payments          Payment[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([clientId])
}

model Payment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  receiptNumber Int?
  amount        Float
  lateFeeAmount Float?   // porción de `amount` que corresponde a mora (no amortiza capital)
  date          DateTime @default(now())
  method        String   // "cash", "transfer", etc.
  loanId        String   @db.ObjectId
  loan          Loan     @relation(fields: [loanId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([loanId])
}

model Settings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @unique @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  value     Json
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}
